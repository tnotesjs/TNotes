{
  "name": "tnotes",
  "version": "0.0.1",
  "type": "module",
  "description": "笔记管理工具",
  "main": "scripts/index.js",
  "devDependencies": {
    "markdown-it-task-lists": "^2.1.1",
    "npm-run-all": "^4.1.5",
    "vitepress": "^1.6.3"
  },
  "scripts": {
    "docs:dev": "         npm run update-home && vitepress dev docs --host --port 0629 --open",
    "update-home": "      node scripts/gen-index-md.js",
    "docs:publish": "     npm run update-home && node scripts/docs-publish.js",
    "docs:build": "       vitepress build docs",
    "docs:preview": "     vitepress preview docs",
    "updateAll": "        npm-run-all --parallel update:*",
    "syncAll": "          npm-run-all --parallel sync:*"
  },
  "packageManager": "pnpm@9.0.4+sha512.c374b52de3de88c58fd8333df664a737279cdb0e1344ba4054d3b1fffa9a1a3670854f755dca4f16adea3f14be9896a7fcaf167409fe0c1ad60475271dafe81a",
  "dependencies": {
    "github-slugger": "^2.0.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-mathjax3": "^4.3.2",
    "marked": "^15.0.11",
    "minimist": "^1.2.8",
    "swiper": "^11.2.1",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue": "^3.5.13"
  }
}
